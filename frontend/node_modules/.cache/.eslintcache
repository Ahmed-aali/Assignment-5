[{"C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\index.js":"1","C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\App.js":"2","C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\reportWebVitals.js":"3","C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\Routes.js":"4","C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\Student.js":"5","C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\Home.js":"6","C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\Teacher.js":"7"},{"size":552,"mtime":1772358158000,"results":"8","hashOfConfig":"9"},{"size":202,"mtime":1772358158000,"results":"10","hashOfConfig":"9"},{"size":375,"mtime":1772358158000,"results":"11","hashOfConfig":"9"},{"size":519,"mtime":1772358158000,"results":"12","hashOfConfig":"9"},{"size":4728,"mtime":1772358158000,"results":"13","hashOfConfig":"9"},{"size":646,"mtime":1772358158000,"results":"14","hashOfConfig":"9"},{"size":4771,"mtime":1772368066000,"results":"15","hashOfConfig":"9"},{"filePath":"16","messages":"17","suppressedMessages":"18","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"11xjone",{"filePath":"19","messages":"20","suppressedMessages":"21","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"22","messages":"23","suppressedMessages":"24","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"25","messages":"26","suppressedMessages":"27","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"28","messages":"29","suppressedMessages":"30","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"31"},{"filePath":"32","messages":"33","suppressedMessages":"34","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"35","messages":"36","suppressedMessages":"37","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"38"},"C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\index.js",[],[],"C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\App.js",[],[],"C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\reportWebVitals.js",[],[],"C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\Routes.js",[],[],"C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\Student.js",["39"],[],"// Student.js\r\n\r\nimport React, { useState, useEffect } from 'react';\r\nimport './Student.css';\r\n\r\nfunction Student() {\r\n  const [studentData, setStudentData] = useState({\r\n    name: '',\r\n    rollNo: '',\r\n    class: '',\r\n  });\r\n  const [data, setData]= useState([])\r\n\r\n  const API_BASE_URL = process.env.REACT_APP_API_BASE_URL;\r\n\r\n  console.log(\"API\",API_BASE_URL)\r\nconst getData=()=> {\r\n  fetch(`${API_BASE_URL}/student`)\r\n  .then((res) => res.json())\r\n  .then((data) => {\r\n    console.log('Fetched Data:', data);\r\n    setData(data);\r\n  })\r\n  .catch((err) => console.log(err));\r\n}\r\n\r\n  useEffect(() => {\r\n    getData()\r\n  }, []); \r\n\r\n  const handleInputChange = (e) => {\r\n    const { name, value } = e.target;\r\n    setStudentData({ ...studentData, [name]: value });\r\n  };\r\n\r\n  const handleSubmit = (e) => {\r\n    e.preventDefault();\r\n    setStudentData({\r\n      name: '',\r\n      rollNo: '',\r\n      class: '',\r\n    });\r\n    const requestOptions = {\r\n      method: 'POST',\r\n      headers: { 'Content-Type': 'application/json' },\r\n      body: JSON.stringify( studentData )\r\n  };\r\n    \r\n    fetch(`${API_BASE_URL}/addstudent`, requestOptions ).then((res) => res.json())\r\n.then(() => {\r\ngetData()})\r\n      .catch((err) => console.log(err));\r\n  };\r\n  const handleDelete = (id) => {\r\n    fetch(`${API_BASE_URL}/student/${id}`, {\r\n      method: 'DELETE',\r\n    })\r\n      .then((res) => res.json())\r\n      .then(() => {\r\n        getData();\r\n      })\r\n      .catch((err) => console.error('Error deleting data:', err));\r\n  };\r\n\r\n  return (\r\n    <div>\r\n    <div className=\"student-container\">\r\n      <div className=\"content\">\r\n        <h2 className='store-student-details'style={{ marginLeft: '100px' }}>Student Details</h2>\r\n        <form onSubmit={handleSubmit}>\r\n          <div className=\"form-group\">\r\n            <label>Name:</label>\r\n            <input\r\n              type=\"text\"\r\n              name=\"name\"\r\n              value={studentData.name}\r\n              onChange={handleInputChange}\r\n              required\r\n            />\r\n          </div>\r\n          <div className=\"form-group\">\r\n            <label>Roll No (Must be Number):</label>\r\n            <input\r\n              type=\"text\"\r\n              name=\"rollNo\"\r\n              value={studentData.rollNo}\r\n              onChange={handleInputChange}\r\n              required\r\n            />\r\n          </div>\r\n          <div className=\"form-group\">\r\n            <label>Class:</label>\r\n            <input\r\n              type=\"text\"\r\n              name=\"class\"\r\n              value={studentData.class}\r\n              onChange={handleInputChange}\r\n            />\r\n          </div>\r\n          <div className=\"form-group\">\r\n          <p style={{ marginLeft: '50px' }}>\r\n            <button type=\"submit\">Submit</button>\r\n            </p>\r\n          </div>\r\n        </form>\r\n      </div>\r\n      <div style={{ display: 'flex', justifyContent: 'flex-end', padding: '50px 0' }}>\r\n      <h2 className='student-details'>Student details</h2>\r\n      <table className=\"student-table gradient-bg\" style={{ border: '1px solid #ccc', borderCollapse: 'collapse', margin: '100px 0',marginLeft: '800px', marginTop: '200px', width: '40%', backgroundColor: '#f4f4f4'}}>\r\n        <thead>\r\n          <tr style={{ backgroundColor: '#ddd' }}>\r\n          <td style={{ border: '1px solid #ccc', padding: '8px', textAlign: 'center' }}>StudentID</td>\r\n            <th style={{ border: '1px solid #ccc', padding: '8px', textAlign: 'center' }}>Name</th>\r\n            <th style={{ border: '1px solid #ccc', padding: '8px', textAlign: 'center' }}>Roll Number</th>\r\n            <th style={{ border: '1px solid #ccc', padding: '8px', textAlign: 'center' }}>Class</th>\r\n            <th style={{ border: '1px solid #ccc', padding: '8px', textAlign: 'center' }}>Actions</th>\r\n          </tr>\r\n        </thead>\r\n        <tbody>\r\n          {data.map((d, i) => (\r\n            <tr key={i} style={{ backgroundColor: i % 2 === 0 ? '#f9f9f9' : '#fff' }}>\r\n              <td style={{ border: '1px solid #ccc', padding: '8px', textAlign: 'center' }}>{d.id}</td>\r\n              <td style={{ border: '1px solid #ccc', padding: '8px', textAlign: 'center' }}>{d.name}</td>\r\n              <td style={{ border: '1px solid #ccc', padding: '8px', textAlign: 'center' }}>{d.roll_number}</td>\r\n              <td style={{ border: '1px solid #ccc', padding: '8px', textAlign: 'center' }}>{d.class}</td>\r\n              <td style={{ border: '1px solid #ccc', padding: '8px', textAlign: 'center' }}>\r\n        <button className=\"delete-button\" onClick={() => handleDelete(d.id)}>Delete</button>\r\n      </td>\r\n            </tr>\r\n          ))}\r\n        </tbody>\r\n      </table>\r\n    </div>\r\n    </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default Student;","C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\Home.js",[],[],"C:\\Users\\LOQ\\OneDrive\\Desktop\\app div\\Lab1\\frontend\\src\\Teacher.js",["40"],[],"// Teacher.js\r\n\r\nimport React, { useState, useEffect } from 'react';\r\nimport './Teacher.css';\r\n\r\nfunction Teacher() {\r\n  const [TeacherData, setTeacherData] = useState({\r\n    name: '',\r\n    subject: '',\r\n    class: ''\r\n  });\r\n\r\n  const [data, setData] = useState([])\r\n\r\n  const API_BASE_URL = process.env.REACT_APP_API_BASE_URL;\r\n  console.log(\"API\", API_BASE_URL)\r\n  const getData = () => {\r\n    fetch(`${API_BASE_URL}/teacher`)\r\n      .then((res) => res.json())\r\n      .then((data) => setData(data))\r\n      .catch((err) => console.log(err));\r\n  }\r\n\r\n  useEffect(() => {\r\n    getData()\r\n  }, []);\r\n\r\n  const handleInputChange = (e) => {\r\n    const { name, value } = e.target;\r\n    setTeacherData({ ...TeacherData, [name]: value });\r\n  };\r\n\r\n  const handleSubmit = (e) => {\r\n    e.preventDefault();\r\n    setTeacherData({\r\n      name: '',\r\n      subject: '',\r\n      class: '',\r\n    });\r\n\r\n\r\n    const requestOptions = {\r\n      method: 'POST',\r\n      headers: { 'Content-Type': 'application/json' },\r\n      body: JSON.stringify(TeacherData)\r\n    };\r\n\r\n    fetch(`${API_BASE_URL}/addteacher`, requestOptions).then((res) => res.json())\r\n      .then(() => {\r\n        getData()\r\n      }\r\n      )\r\n      .catch((err) => console.log(err));\r\n  };\r\n\r\n  const handleDelete = (id) => {\r\n    fetch(`${API_BASE_URL}/teacher/${id}`, {\r\n      method: 'DELETE',\r\n    })\r\n      .then((res) => res.json())\r\n      .then(() => {\r\n        getData();\r\n      })\r\n      .catch((err) => console.error('Error deleting data:', err));\r\n  };\r\n\r\n  return (\r\n    <div className=\"Teacher-container\">\r\n      <div className=\"content\">\r\n        <h2 className='store-teacher-details' style={{ marginLeft: '100px' }}>Teacher Details</h2>\r\n        <form onSubmit={handleSubmit}>\r\n          <div className=\"form-group\">\r\n            <label>Name:</label>\r\n            <input\r\n              type=\"text\"\r\n              name=\"name\"\r\n              value={TeacherData.name}\r\n              onChange={handleInputChange}\r\n              required\r\n            />\r\n          </div>\r\n          <div className=\"form-group\">\r\n            <label>Subject:</label>\r\n            <input\r\n              type=\"text\"\r\n              name=\"subject\"\r\n              value={TeacherData.subject}\r\n              onChange={handleInputChange}\r\n              required\r\n            />\r\n          </div>\r\n          <div className=\"form-group\">\r\n            <label>Class:</label>\r\n            <input\r\n              type=\"text\"\r\n              name=\"class\"\r\n              value={TeacherData.class}\r\n              onChange={handleInputChange}\r\n            />\r\n          </div>\r\n          <div className=\"form-group\">\r\n            <p style={{ marginLeft: '50px' }}>\r\n              <button type=\"submit\">Submit</button>\r\n            </p>\r\n          </div>\r\n        </form>\r\n      </div>\r\n      <div style={{ display: 'flex', justifyContent: 'flex-end', padding: '50px 0' }}>\r\n        <h2 className='teacher-details'>Teacher details</h2>\r\n        <table className=\"student-table gradient-bg\" style={{ border: '1px solid #ccc', borderCollapse: 'collapse', margin: '100px 0', marginLeft: '825px', marginTop: '200px', width: '40%', backgroundColor: '#f4f4f4' }}>\r\n          <thead>\r\n            <tr style={{ backgroundColor: '#ddd' }}>\r\n              <td style={{ border: '1px solid #ccc', padding: '15px', textAlign: 'center' }}>TeacherID</td>\r\n              <th style={{ border: '1px solid #ccc', padding: '15px', textAlign: 'center' }}>Name</th>\r\n              <th style={{ border: '1px solid #ccc', padding: '15px', textAlign: 'center' }}>Subject</th>\r\n              <th style={{ border: '1px solid #ccc', padding: '15px', textAlign: 'center' }}>Class</th>\r\n              <th style={{ border: '1px solid #ccc', padding: '15px', textAlign: 'center' }}>Actions</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            {data.map((d, i) => (\r\n              <tr key={i} style={{ backgroundColor: i % 2 === 0 ? '#f9f9f9' : '#fff' }}>\r\n                <td style={{ border: '1px solid #ccc', padding: '15px', textAlign: 'center' }}>{d.id}</td>\r\n                <td style={{ border: '1px solid #ccc', padding: '15px', textAlign: 'center' }}>{d.name}</td>\r\n                <td style={{ border: '1px solid #ccc', padding: '15px', textAlign: 'center' }}>{d.subject}</td>\r\n                <td style={{ border: '1px solid #ccc', padding: '15px', textAlign: 'center' }}>{d.class}</td>\r\n                <td style={{ border: '1px solid #ccc', padding: '15px', textAlign: 'center' }}>\r\n                  <button className=\"delete-button\" onClick={() => handleDelete(d.id)}>Delete</button>\r\n                </td>\r\n              </tr>\r\n            ))}\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default Teacher;\r\n",{"ruleId":"41","severity":1,"message":"42","line":29,"column":6,"nodeType":"43","endLine":29,"endColumn":8,"suggestions":"44"},{"ruleId":"41","severity":1,"message":"42","line":26,"column":6,"nodeType":"43","endLine":26,"endColumn":8,"suggestions":"45"},"react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'getData'. Either include it or remove the dependency array.","ArrayExpression",["46"],["47"],{"desc":"48","fix":"49"},{"desc":"48","fix":"50"},"Update the dependencies array to be: [getData]",{"range":"51","text":"52"},{"range":"53","text":"52"},[624,626],"[getData]",[593,595]]